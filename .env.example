# vic-os Dashboard Environment Variables Template

# Set to True for development, False for production
DEBUG=True

# Unique secret key for your project (generate a new one for production)
SECRET_KEY=your-django-insecure-secret-key-here

# Comma-separated list of allowed hosts
ALLOWED_HOSTS=localhost,127.0.0.1,.render.com

# PostgreSQL Connection String (required for production/Render)
# DATABASE_URL=postgres://user:password@hostname:5432/dbname

# Redis Connection String (required if using Redis Channel Layer)
REDIS_URL=redis://localhost:6379/0

# Port for the application (default 8000)
PORT=8000
